rules_version = '2';

// PulseCRM Firestore security rules.
// Deploy with: firebase deploy --only firestore:rules
//
// Requires Firebase Authentication with Google sign-in enabled.
// Allows read/write only for signed-in users whose verified Google email
// is on the @merchantsbi.com Workspace domain.
//
// To allow any signed-in Google account, remove the two email lines.
// To use an explicit allowlist, replace the email check with:
//   && request.auth.token.email in ['a@x.com', 'b@x.com']
service cloud.firestore {
  match /databases/{database}/documents {
    match /{collection}/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@merchantsbi[.]com$')
        && collection in ['contacts', 'companies', 'deals', 'tasks', 'activities', 'members', 'tickets', 'products', 'templates', 'supportCategories', 'slaRules', 'quotes', 'quoteSettings', 'pipelineStages'];
    }
  }
}
